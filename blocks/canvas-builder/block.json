{
  "apiVersion": 3,
  "name": "ignite-bookings/editable-container",
  "title": "Ignite Container",
  "category": "design",
  "icon": "layout",
  "description": "A simple container for nested blocks.",
  "textdomain": "ignite-bookings",
  "editorScript": "file:./editor.js",
  "editorStyle":  "file:./editor.css",
  "render":       "file:./render.php",
  "supports": {
    "html": false,
    "anchor": true,
    "align": ["wide", "full"],
    "dimensions": { "minHeight": true },
    "layout": {
      "default": { "type": "flow" },
      "allowSwitching": true
    },
    "spacing": { "margin": true, "padding": true, "blockGap": true },
    "color":   { "text": true, "background": true, "gradients": true },
    "border":  { "color": true, "radius": true, "style": true, "width": true }
  }
}